# Настройки локального запуска «на своём железе» (источается setup_local.sh и run_local.sh).
# Любую переменную можно переопределить заранее:
#   AIDND_MODEL=qwen2.5:3b-instruct ./scripts/run_local.sh        # для машин послабее
#   OLLAMA_HOST=http://localhost:11434 ./scripts/setup_local.sh

export OLLAMA_HOST="${OLLAMA_HOST:-http://localhost:11434}"
export AIDND_MODEL="${AIDND_MODEL:-qwen2.5:7b-instruct}"                  # нарратив · когниция · бой · квесты
export AIDND_INTENT_MODEL="${AIDND_INTENT_MODEL:-qwen2.5:1.5b-instruct}"  # лёгкий классификатор интента
