# Конфиг тренировочного пайплайна. source config.env перед запуском скриптов.
#
# ВАЖНО: BASE_HF (репозиторий для обучения) и BASE_OLLAMA (тег для инференса)
# должны указывать на ОДНИ И ТЕ ЖЕ веса — иначе LoRA-адаптер не приложится к базе.

# --- база: Qwen3.5-9B (продакшен-база движка). HF (обучение) ↔ Ollama-тег (инференс) — одна модель ---
# Арх qwen35: Gated DeltaNet + sparse MoE, мультимодальная (тренируем только текст). Грузится FastModel.
export BASE_HF="${BASE_HF:-unsloth/Qwen3.5-9B}"
export BASE_OLLAMA="${BASE_OLLAMA:-qwen3.5:9b}"

# --- сервер (механизм доступа из ai-dnd: SSH-туннель к Ollama на RTX 4070 Ti Super) ---
export SERVER="${DND_SERVER:-nikalutis@192.168.3.26}"
export REMOTE_DIR="${REMOTE_DIR:-aidnd-training}"
export OLLAMA_HOST="${OLLAMA_HOST:-http://localhost:11434}"

# --- что тренируем: адаптер -> исходный jsonl (от корня репозитория) ---
# quest      -> datasets/quests/quests.jsonl       (200 примеров)
# freeform   -> datasets/freeform/freeform.jsonl   (router+arbiter+consequence)
# narrator   -> datasets/narrator/narrator.jsonl   (проза: исход/диалог/обстановка по mode)
export ADAPTER="${ADAPTER:-quest}"
# SRC_JSONL по умолчанию выводится из ADAPTER (можно переопределить переменной окружения)
case "$ADAPTER" in
  quest)       export SRC_JSONL="${SRC_JSONL:-datasets/quests/quests.jsonl}";;
  router)      export SRC_JSONL="${SRC_JSONL:-datasets/freeform/router.jsonl}";;
  arbiter)     export SRC_JSONL="${SRC_JSONL:-datasets/freeform/arbiter.jsonl}";;
  consequence) export SRC_JSONL="${SRC_JSONL:-datasets/freeform/consequence.jsonl}";;
  freeform)    export SRC_JSONL="${SRC_JSONL:-datasets/freeform/freeform.jsonl}";;
  narrator)    export SRC_JSONL="${SRC_JSONL:-datasets/narrator/narrator.jsonl}";;
  *)           export SRC_JSONL="${SRC_JSONL:-datasets/quests/quests.jsonl}";;
esac

# --- гиперпараметры QLoRA (16 ГБ VRAM → 4-bit) ---
export EPOCHS="${EPOCHS:-3}"
export LR="${LR:-2e-4}"
export LORA_R="${LORA_R:-16}"
export LORA_ALPHA="${LORA_ALPHA:-32}"
export MAX_SEQ="${MAX_SEQ:-2048}"   # макс. пример ~1077 ток. → 2048 без обрезки, VRAM с запасом
export BATCH="${BATCH:-2}"
export GRAD_ACCUM="${GRAD_ACCUM:-8}"
export EVAL_HOLDOUT="${EVAL_HOLDOUT:-20}"
export SEED="${SEED:-1337}"
